clean: compiler_clean 
	-$(DEL_FILE) debug\Account.o debug\ActiveMoney.o debug\Administrator.o debug\Calculator.o debug\ChangeMenu.o debug\Exception.o debug\Functions.o debug\Human.o debug\Sign.o debug\TransferMoney.o debug\main.o debug\mainwindow.o debug\Money.o debug\Service.o debug\User.o debug\qrc_Pictures.o debug\moc_Calculator.o debug\moc_ChangeMenu.o debug\moc_Sign.o debug\moc_mainwindow.o
	-$(DEL_FILE) debug\icon_bank_connect.txt

distclean: clean 
	-$(DEL_FILE) .qmake.stash
	-$(DEL_FILE) $(DESTDIR_TARGET)
	-$(DEL_FILE) Makefile.Debug

mocclean: compiler_moc_header_clean compiler_moc_objc_header_clean compiler_moc_source_clean

mocables: compiler_moc_header_make_all compiler_moc_objc_header_make_all compiler_moc_source_make_all

check: first

benchmark: first

compiler_no_pch_compiler_make_all:
compiler_no_pch_compiler_clean:
compiler_rcc_make_all: debug/qrc_Pictures.cpp
compiler_rcc_clean:
	-$(DEL_FILE) debug\qrc_Pictures.cpp
debug/qrc_Pictures.cpp: Pictures.qrc \
		../../../Programs/Qt/6.4.0/mingw_64/bin/rcc.exe \
		Pictures/admin.jpg \
		Pictures/deposit_background.png \
		Pictures/credits_background.png \
		Pictures/account_edit.png \
		Pictures/transfer_background.jpg \
		Pictures/main_background.png \
		Pictures/account_background.png \
		Pictures/account_bank.jpg
	D:\Programs\Qt\6.4.0\mingw_64\bin\rcc.exe -name Pictures --no-zstd Pictures.qrc -o debug\qrc_Pictures.cpp

compiler_moc_predefs_make_all: debug/moc_predefs.h
compiler_moc_predefs_clean:
	-$(DEL_FILE) debug\moc_predefs.h
debug/moc_predefs.h: ../../../Programs/Qt/6.4.0/mingw_64/mkspecs/features/data/dummy.cpp
	g++ -fno-keep-inline-dllexport -g -std=gnu++1z -Wall -Wextra -Wextra -dM -E -o debug\moc_predefs.h ..\..\..\Programs\Qt\6.4.0\mingw_64\mkspecs\features\data\dummy.cpp

